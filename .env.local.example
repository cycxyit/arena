# Storage
# Local default: Python + data/arena.db
# Vercel hosted: Turso/libSQL remote SQLite
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
NEXT_PUBLIC_SITE_URL=

# Market data
ALPHAVANTAGE_API_KEY=
ALPHAVANTAGE_API_KEYS=
ALPHAVANTAGE_REQUEST_DELAY_SECONDS=1.1

# Automatic/LLM timeouts
LLM_TIMEOUT_SECONDS=45

# OpenAI seat
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# OpenRouter seat
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# Gemini seat
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# SiliconFlow seat
SILICONFLOW_API_KEY=
SILICONFLOW_MODEL=Qwen/Qwen2.5-72B-Instruct
